{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
		"emitDeclarationOnly": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node", "vite/client"],
		"lib": ["esnext", "dom"]
	},
	"include": ["src/**/*.ts"],
	"references": [
		{
			"path": "../../ui/ui-manager/tsconfig.lib.json"
		},
		{
			"path": "../../ui/data-access/tsconfig.lib.json"
		},
		{
			"path": "../models/tsconfig.lib.json"
		}
	],
	"exclude": [
		"vite.config.ts",
		"vite.config.mts",
		"vitest.config.ts",
		"vitest.config.mts",
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.tsx",
		"src/**/*.test.js",
		"src/**/*.spec.js",
		"src/**/*.test.jsx",
		"src/**/*.spec.jsx"
	]
}
